# App URL — your production domain (used in invite emails, auth redirects, RSVP links)
# CRITICAL: Set this to your Vercel URL so invite links always work
VITE_APP_URL=https://amorisuite.com

# Supabase — copy this file to .env and fill in your values
# Find these in: Supabase Dashboard → Your Project → Project Settings → API
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# Dev login bypass — ONLY for local development, NEVER set in production
# Set a password on your test account in Supabase Dashboard → Authentication → Users
# VITE_DEV_MODE=true
# VITE_DEV_EMAIL=your-test@email.com
# VITE_DEV_PASSWORD=your-test-password

# Stripe — used by the Supabase edge function (not exposed to browser)
# Deploy edge function: supabase functions deploy create-checkout
# Set secrets:  supabase secrets set STRIPE_SECRET_KEY=sk_test_...
#               supabase secrets set STRIPE_PRICE_ID=price_...
# The STRIPE_PRICE_ID is the ID of your $49/mo recurring price in Stripe dashboard.
VITE_STRIPE_PUBLIC_KEY=pk_test_your-publishable-key-here

# Resend (for invite emails) — NOT used in the browser, only set as a Supabase secret
# Get your API key at: https://resend.com/api-keys
# Then run: npx supabase secrets set RESEND_API_KEY=re_your_key_here
